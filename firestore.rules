rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthed() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuthed() && request.auth.uid == uid;
    }

    function ownerAllowedFields() {
      return request.resource.data.diff(resource.data).changedKeys().hasOnly([
        'displayName',
        'phoneE164',
        'location',
        'phoneVerified',
        'phoneVerifiedAt',
        'smsAlertsEnabled',
        'updatedAt'
      ]);
    }

    // App user profile
    match /users/{uid} {
      allow read: if isOwner(uid);
      allow create: if isOwner(uid);

      // Owner can edit only their profile fields.
      // phoneVerified/phoneVerifiedAt should normally be set by trusted backend,
      // but keeping this allowed avoids breaking current app flow.
      allow update: if isOwner(uid) && ownerAllowedFields();
      allow delete: if false;
    }

    // OTP storage: only backend should access.
    match /phoneVerifications/{uid} {
      allow read, write: if false;
    }

    // SMS dispatch logs: only backend should write.
    match /smsDispatchLogs/{docId} {
      allow read, write: if false;
    }

    // Alert state: backend internal state.
    match /system/{docId} {
      allow read, write: if false;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
